# Copy this file to .env and adjust values as needed.
# All variables have sensible defaults defined in src/config.py.

# ── Model ──────────────────────────────────────────────────────────────────────
# Points to backend/models/ by default (resolved relative to src/config.py).
MODEL_DIR=../models
MODEL_FILENAME=Custom_CNN.keras

# Decision threshold for malignant classification.
# Tuned to 0.34 via precision-recall analysis — lower = higher recall (fewer missed malignants).
PREDICTION_THRESHOLD=0.34

# ── Upload validation ─────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── Monitoring ────────────────────────────────────────────────────────────────
# Points to backend/logs/ by default.
LOG_DIR=../logs
METRICS_WINDOW_SIZE=500

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local dev: *
# Production: https://yourapp.com,https://www.yourapp.com
CORS_ORIGINS=*

# ── Server ────────────────────────────────────────────────────────────────────
APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=8000
